# 应用配置
APP_NAME=航空零件采购比价系统
DEBUG=True

# 数据库配置
# 阶段一：SQLite（单用户）
DATABASE_URL=sqlite:///./data/quotes.db

# 阶段二：PostgreSQL（多用户）
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/quotes_db

# 邮件服务器配置（可选）
# EMAIL_USER=your_email@example.com
# EMAIL_PASSWORD=your_password_or_auth_code
# EMAIL_IMAP_SERVER=imap.example.com
# EMAIL_IMAP_PORT=993

# LLM 配置（DeepSeek / OpenAI 兼容 API）
# 从 https://platform.deepseek.com/api_keys 获取
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
# 模型可选: deepseek-chat / deepseek-reasoner 等
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3

# 汇率换算公式配置（默认值）
EXCHANGE_RATE=7.2
ADDITIONAL_FEE=0.0
SERVICE_FEE_RATE=0.0
